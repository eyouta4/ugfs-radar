# UGFS-Radar — Variables d'environnement
# Copier ce fichier en .env et remplir les vraies valeurs.
# JAMAIS committer le .env.

# === Database ===
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://ugfs:ugfs@localhost:5432/ugfs_radar
DATABASE_URL_SYNC=postgresql+psycopg2://ugfs:ugfs@localhost:5432/ugfs_radar

# === LLM ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback (optionnel) — décommenter si besoin
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# === Embeddings ===
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_MODEL=voyage-3-lite

# === Email ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="UGFS-Radar <radar@ugfs-na.com>"
# Liste séparée par virgules
EMAIL_TO=ines@ugfs-na.com,lotfi@ugfs-na.com,sarra@ugfs-na.com
EMAIL_CC=

# === Web search (Google Custom Search) ===
GOOGLE_CSE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxx

# === Microsoft Teams (alertes urgentes) ===
TEAMS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEAMS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEAMS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=
TEAMS_ENABLED=false

# === Observability ===
SENTRY_DSN=
LOG_LEVEL=INFO
ENVIRONMENT=development

# === Scheduler ===
TIMEZONE=Africa/Tunis
WEEKLY_RUN_DAY=mon
WEEKLY_RUN_HOUR=7
WEEKLY_RUN_MINUTE=0

# === Scoring ===
URGENT_DEADLINE_DAYS=7
SIMILARITY_BOOST_THRESHOLD=0.85
SIMILARITY_BOOST_POINTS=10

# === API (feedback ingestion) ===
API_HOST=0.0.0.0
API_PORT=8000
# Token pour ingestion API + secret JWT (générer : python -c "import secrets; print(secrets.token_urlsafe(48))")
API_FEEDBACK_TOKEN=change-me-to-a-random-string-in-prod
